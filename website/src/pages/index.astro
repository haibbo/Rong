---
import { Code } from "astro:components";
import Layout from "../layouts/Layout.astro";
import { MODULES } from "../data/modules";
import { SITE_VERSION, SITE_VERSION_MINOR } from "../data/version";

const repo = "https://github.com/LingXia-Dev/Rong";
const base = import.meta.env.BASE_URL;

const stats = [
  ["3", "JavaScript engines"],
  ["20", "built-in modules"],
  ["1.90+", "Rust toolchain (2024 edition)"],
  ["MIT / Apache-2.0", "dual licensed"],
];

const features = [
  {
    icon: "M4 7h16M4 12h16M4 17h10",
    title: "Unified API",
    body: "Write once, run anywhere. The same Rust code drives QuickJS, JavaScriptCore, and ArkJS — engines are selected at build time, with no engine-specific branches in your code.",
  },
  {
    icon: "M12 2l3 3-3 3-3-3 3-3zM12 16l3 3-3 3-3-3 3-3zM2 12l3-3 3 3-3 3-3-3zM16 12l3-3 3 3-3 3-3-3z",
    title: "Declarative class bindings",
    body: "Expose Rust structs to JavaScript with #[js_export], #[js_class], and #[js_method] — constructors, getters, setters, and static methods, all type-checked by Rust.",
  },
  {
    icon: "M13 2L3 14h7l-1 8 10-12h-7l1-8z",
    title: "Async / await",
    body: "First-class Promise and async iterator integration so JavaScript and Rust futures interleave naturally across the engine boundary.",
  },
  {
    icon: "M3 3h7v7H3zM14 3h7v7h-7zM14 14h7v7h-7zM3 14h7v7H3z",
    title: "Worker pools",
    body: "Choose your execution model explicitly: shared() workers for stateless work, pinned() workers for keyed state that must live on the same long-lived runtime.",
  },
  {
    icon: "M12 2a10 10 0 100 20 10 10 0 000-20zM2 12h20",
    title: "Cross-platform CI",
    body: "Continuously tested on Windows, Linux, and macOS — QuickJS everywhere, system JavaScriptCore on macOS, and source-built JSC consumers on all three.",
  },
  {
    icon: "M12 5v14M5 12h14",
    title: "TypeScript & tooling",
    body: "Type definitions ship as @rongjs/rong on npm, and @rongjs/rong-skill packages an installable agent skill with generated API references.",
  },
];

const engines = [
  {
    name: "QuickJS",
    tag: "Default · Desktop",
    body: "Lightweight and fast. The default engine for the Rong CLI on desktop hosts, paired with the aws-lc TLS backend.",
    accent: "var(--jade)",
  },
  {
    name: "JavaScriptCore",
    tag: "Apple system + source builds",
    body: "Links the system JavaScriptCore.framework on macOS and iOS, or pinned source-built WebKit/JSCOnly artifacts on macOS, Linux, and Windows.",
    accent: "var(--celadon)",
  },
  {
    name: "ArkJS",
    tag: "HarmonyOS / OpenHarmony",
    body: "The HarmonyOS JavaScript engine, for aarch64 OpenHarmony targets with the ring TLS backend.",
    accent: "var(--gold)",
  },
];

const modules = MODULES;

const quickStart = `use rong::*;

fn main() -> Result<(), Box<dyn std::error::Error>> {
    // Create a JavaScript runtime and context
    let rt = RongJS::runtime();
    let ctx = rt.context();

    // Execute JavaScript directly
    let result: i32 = ctx.eval(Source::from_bytes(b"2 + 3"))?;
    println!("Result: {}", result); // Result: 5

    Ok(())
}`;

const workerPool = `use rong::{Rong, RongJS, Source};

#[tokio::main]
async fn main() -> Result<(), Box<dyn std::error::Error>> {
    // shared() for stateless work on any available worker;
    // pinned::<K, S>() keeps keyed work on the same runtime.
    let rong = Rong::<RongJS>::builder().shared().workers(2).build()?;

    let value: i32 = rong.call(|runtime, _receiver| async move {
        let ctx = runtime.context();
        ctx.eval(Source::from_bytes(b"21 * 2"))
    }).await?;

    println!("JS result: {value}"); // JS result: 42
    Ok(())
}`;

const classBindings = `use rong::*;
use rong::{js_class, js_export, js_method};

#[js_export]
struct Point { x: i32, y: i32 }

#[js_class(rename = "Point2D")]
impl Point {
    #[js_method(constructor)]
    fn new(x: i32, y: i32) -> Self { Self { x, y } }

    #[js_method(getter, enumerable)]
    fn x(&self) -> i32 { self.x }

    #[js_method(rename = "moveBy")]
    fn move_by(&mut self, dx: i32, dy: i32) {
        self.x += dx;
        self.y += dy;
    }

    // Static method: Point2D.origin()
    #[js_method]
    fn origin() -> Self { Self { x: 0, y: 0 } }
}

fn main() -> Result<(), Box<dyn std::error::Error>> {
    let rt = RongJS::runtime();
    let ctx = rt.context();

    // Register once, then use from JavaScript:
    //   const p = new Point2D(1, 2); p.moveBy(3, 4);
    ctx.register_class::<Point>()?;
    Ok(())
}`;

const cargoToml = `[dependencies]
# Engines are mutually exclusive — pick one, plus a TLS backend.
# Desktop: tls-aws-lc · HarmonyOS/OpenHarmony: tls-ring
rong = { version = "${SITE_VERSION_MINOR}", features = ["quickjs", "tls-aws-lc"] }`;

const cliUsage = `# Run the Rong CLI / REPL — QuickJS + aws-lc by default on desktop
cargo run -p rong_cli

# Switch to JavaScriptCore explicitly
cargo run -p rong_cli --no-default-features --features jscore,tls-aws-lc

# Build for ArkJS on OpenHarmony targets
cargo build --no-default-features --features arkjs,tls-ring \\
  --target aarch64-unknown-linux-ohos`;
---

<Layout>
  <!-- HERO -->
  <section class="hero">
    <div class="hero-glyph" aria-hidden="true">融</div>
    <div class="container hero-inner">
      <a class="hero-badge" href={`${repo}/blob/master/CHANGELOG.md`} target="_blank" rel="noopener">
        <span class="dot"></span> v{SITE_VERSION} · See what's new
      </a>
      <h1>
        One JavaScript API.<br />
        <span class="gradient-text">Every engine, in Rust.</span>
      </h1>
      <p class="hero-sub">
        <strong>Rong</strong> (融) is a JavaScript runtime for Rust with a unified API over
        QuickJS, JavaScriptCore, and ArkJS — built for embedding, Rust-driven JS APIs,
        and long-lived worker runtimes.
      </p>
      <div class="hero-cta">
        <a class="btn btn-primary" href="#start">
          Get started
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
        </a>
        <a class="btn btn-ghost" href={repo} target="_blank" rel="noopener">View on GitHub</a>
      </div>
      <div class="hero-install">
        <code>cargo add rong --features quickjs,tls-aws-lc</code>
        <button class="copy-btn" data-copy="cargo add rong --features quickjs,tls-aws-lc" aria-label="Copy install command">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
        </button>
      </div>
      <ul class="hero-engines" aria-label="Supported engines">
        <li><span style="--c:var(--jade)"></span>QuickJS</li>
        <li><span style="--c:var(--celadon)"></span>JavaScriptCore</li>
        <li><span style="--c:var(--gold)"></span>ArkJS</li>
      </ul>
    </div>
  </section>

  <!-- STATS -->
  <div class="stats-band">
    <div class="container stats" data-reveal>
      {stats.map(([n, label]) => (
        <div class="stat">
          <span class="stat-n">{n}</span>
          <span class="stat-label">{label}</span>
        </div>
      ))}
    </div>
  </div>

  <!-- FEATURES -->
  <section id="features">
    <div class="container">
      <div class="section-head" data-reveal>
        <span class="eyebrow">Why Rong</span>
        <h2>Fusion, harmony, and flow — by design.</h2>
        <p>
          In Chinese, 融 means to merge and harmonize. Rong fuses JavaScript engines with
          Rust native code, unifying diverse runtimes under a single, elegant API.
        </p>
      </div>
      <div class="features-grid">
        {features.map((f, i) => (
          <article class="card feature" data-reveal style={`transition-delay:${i * 60}ms`}>
            <div class="feature-icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d={f.icon}/></svg>
            </div>
            <h3>{f.title}</h3>
            <p>{f.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ENGINES -->
  <section id="engines">
    <div class="container">
      <div class="section-head" data-reveal>
        <span class="eyebrow">Multi-engine support</span>
        <h2>Three engines, one codebase.</h2>
        <p>
          Engines are mutually exclusive and chosen at build time — if multiple engines are
          enabled, the build fails fast. The library ships no default; downstream crates select
          an engine and TLS backend explicitly.
        </p>
      </div>
      <div class="engines-grid">
        {engines.map((e, i) => (
          <article class="card engine" data-reveal style={`transition-delay:${i * 80}ms`}>
            <div class="engine-bar" style={`background:${e.accent}`}></div>
            <span class="engine-tag" style={`color:${e.accent}`}>{e.tag}</span>
            <h3>{e.name}</h3>
            <p>{e.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ARCHITECTURE -->
  <section id="architecture" class="arch-section">
    <div class="container">
      <div class="section-head" data-reveal>
        <span class="eyebrow">Architecture</span>
        <h2>A unified core over swappable engines.</h2>
        <p>
          The Rong core provides the unified API, type system, memory management, and async layer.
          Engines and built-in modules plug in beneath it.
        </p>
      </div>
      <div class="arch" data-reveal>
        <div class="arch-layer arch-core">
          <span class="arch-title">Rong Core</span>
        </div>
        <div class="arch-layer arch-row arch-services">
          <span>Unified API</span><span>Type System</span><span>Memory Management</span><span>Async / Await</span>
        </div>
        <div class="arch-layer arch-row arch-engines">
          <span style="--c:var(--jade)">QuickJS</span>
          <span style="--c:var(--celadon)">JavaScriptCore</span>
          <span style="--c:var(--gold)">ArkJS</span>
        </div>
        <div class="arch-layer arch-modules">
          <span class="arch-modules-title">Built-in Modules &amp; Extensions</span>
          <div class="arch-modules-row">
            <span>Timer</span><span>HTTP</span><span>FS</span><span>Console</span><span>S3</span><span>SQLite</span><span>Redis</span><span>Worker</span><span>…</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CODE -->
  <section id="start">
    <div class="container">
      <div class="section-head" data-reveal>
        <span class="eyebrow">Quick start</span>
        <h2>From zero to evaluating JS in seconds.</h2>
        <p>Add the dependency, pick an engine, and run JavaScript from Rust — or expose Rust classes to JavaScript.</p>
      </div>

      <div class="code-block" data-reveal>
        <div class="code-tabs" role="tablist">
          <button class="code-tab is-active" data-tab="0" role="tab">Embed &amp; eval</button>
          <button class="code-tab" data-tab="1" role="tab">Worker pool</button>
          <button class="code-tab" data-tab="2" role="tab">Class bindings</button>
          <button class="code-tab" data-tab="3" role="tab">Cargo.toml</button>
          <button class="code-tab" data-tab="4" role="tab">CLI</button>
        </div>
        <div class="code-panes">
          <div class="code-pane is-active" data-pane="0"><Code code={quickStart} lang="rust" theme="vitesse-dark" /></div>
          <div class="code-pane" data-pane="1"><Code code={workerPool} lang="rust" theme="vitesse-dark" /></div>
          <div class="code-pane" data-pane="2"><Code code={classBindings} lang="rust" theme="vitesse-dark" /></div>
          <div class="code-pane" data-pane="3"><Code code={cargoToml} lang="toml" theme="vitesse-dark" /></div>
          <div class="code-pane" data-pane="4"><Code code={cliUsage} lang="bash" theme="vitesse-dark" /></div>
        </div>
      </div>
    </div>
  </section>

  <!-- MODULES -->
  <section id="modules" class="modules-section">
    <div class="container">
      <div class="section-head" data-reveal>
        <span class="eyebrow">Batteries included</span>
        <h2>Twenty built-in modules.</h2>
        <p>Common runtime tasks ship in the box — timers, HTTP, file system, storage, workers, Redis, SQLite, S3, and more. Click a module to read its API reference.</p>
      </div>
      <div class="modules-grid">
        {modules.map(([name, desc], i) => (
          <a class="module" href={`${base}/modules/${name}/`} data-reveal style={`transition-delay:${(i % 4) * 50}ms`}>
            <code>{name}</code>
            <span>{desc}</span>
            <svg class="module-arrow" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ECOSYSTEM -->
  <section class="eco-section">
    <div class="container">
      <div class="section-head" data-reveal>
        <span class="eyebrow">Ecosystem</span>
        <h2>Beyond the crate.</h2>
        <p>Rong ships to crates.io and npm, with tooling for TypeScript users and AI agents.</p>
      </div>
      <div class="eco-grid">
        <a class="card eco" data-reveal href="https://crates.io/crates/rong" target="_blank" rel="noopener">
          <span class="eco-kind">crates.io</span>
          <h3>rong</h3>
          <p>The runtime itself, plus per-module crates published in dependency order from a single release workflow.</p>
        </a>
        <a class="card eco" data-reveal style="transition-delay:80ms" href="https://www.npmjs.com/package/@rongjs/rong" target="_blank" rel="noopener">
          <span class="eco-kind">npm</span>
          <h3>@rongjs/rong</h3>
          <p>TypeScript type definitions for the Rong runtime, so JS authored for Rong gets full editor support.</p>
        </a>
        <a class="card eco" data-reveal style="transition-delay:160ms" href="https://www.npmjs.com/package/@rongjs/rong-skill" target="_blank" rel="noopener">
          <span class="eco-kind">npm</span>
          <h3>@rongjs/rong-skill</h3>
          <p>An installable agent skill with self-contained docs and generated API references for AI coding agents.</p>
        </a>
        <a class="card eco" data-reveal style="transition-delay:240ms" href={`${repo}/tree/master/rong_cli`} target="_blank" rel="noopener">
          <span class="eco-kind">CLI</span>
          <h3>rong_cli</h3>
          <p>Local runtime execution and REPL workflows, with engine selection via Cargo features.</p>
        </a>
      </div>
    </div>
  </section>

  <!-- AGENT SKILLS -->
  <section id="skills" class="skills-section">
    <div class="container">
      <div class="section-head" data-reveal>
        <span class="eyebrow">Agent skills</span>
        <h2>Teach your AI agent Rong.</h2>
        <p>
          <code class="inline-code">@rongjs/rong-skill</code> bundles two installable agent skills —
          self-contained <code class="inline-code">SKILL.md</code> documents with generated API references,
          for any agent runtime that supports file-based skills.
        </p>
      </div>
      <div class="skills-grid">
        <article class="card skill-card" data-reveal>
          <h3><code>rong-runtime-developer</code></h3>
          <p>Write Rong JavaScript scripts, choose the right public APIs, adapt examples, run <code class="inline-code">rong_cli</code>, and compile bytecode.</p>
        </article>
        <article class="card skill-card" data-reveal style="transition-delay:80ms">
          <h3><code>rong-module-author</code></h3>
          <p>Write or edit Rust modules that expose Rong APIs, classes, functions, type conversions, and JavaScript errors.</p>
        </article>
      </div>
      <div class="skill-install" data-reveal>
        <code>npx @rongjs/rong-skill install</code>
        <button class="copy-btn" data-copy="npx @rongjs/rong-skill install" aria-label="Copy skill install command">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
        </button>
      </div>
      <p class="skill-note" data-reveal>
        Use <code class="inline-code">--project</code> for a project-local install, or
        <code class="inline-code">--skill &lt;name&gt;</code> to install just one. The skills share their
        source with the module API docs on this site — one source of truth.
      </p>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section">
    <div class="container">
      <div class="cta" data-reveal>
        <div class="cta-glyph" aria-hidden="true">融</div>
        <h2>Bring JavaScript into your Rust application.</h2>
        <p>Embed a runtime, expose Rust-driven APIs, and scale with worker pools — across every supported engine.</p>
        <div class="hero-cta">
          <a class="btn btn-primary" href={repo} target="_blank" rel="noopener">Start building</a>
          <a class="btn btn-ghost" href={`${repo}/blob/master/docs/internals/module_development.md`} target="_blank" rel="noopener">Module guide</a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* HERO */
  .hero {
    position: relative;
    padding-block: clamp(96px, 15vw, 156px) clamp(56px, 8vw, 96px);
    overflow: hidden;
  }
  .hero-glyph {
    position: absolute;
    top: 50%;
    right: -4%;
    transform: translateY(-50%);
    font-size: min(48vw, 620px);
    font-weight: 800;
    line-height: 1;
    background: var(--grad-hero);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    opacity: 0.09;
    pointer-events: none;
    user-select: none;
  }
  .hero-inner { position: relative; max-width: 840px; }
  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    padding: 7px 15px;
    border-radius: 999px;
    background: var(--surface);
    border: 1px solid var(--border-strong);
    font-size: 0.85rem;
    color: var(--text-muted);
    backdrop-filter: blur(8px);
    transition: border-color 0.2s ease, color 0.2s ease;
  }
  .hero-badge:hover { color: var(--text); border-color: var(--jade); }
  .hero-badge .dot {
    width: 7px; height: 7px; border-radius: 50%;
    background: var(--jade);
    box-shadow: 0 0 10px var(--jade);
  }
  .hero h1 {
    font-size: clamp(2rem, 6.4vw, 4.6rem);
    font-weight: 800;
    margin-block: 26px 22px;
  }
  .hero-sub {
    font-size: clamp(1.05rem, 2.2vw, 1.3rem);
    max-width: 600px;
    color: var(--text-muted);
  }
  .hero-sub strong { color: var(--text); }
  .hero-cta { display: flex; flex-wrap: wrap; gap: 14px; margin-top: 34px; }

  .hero-install {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    margin-top: 28px;
    padding: 12px 12px 12px 18px;
    background: #081010;
    border: 1px solid var(--border);
    border-radius: 12px;
    font-family: var(--font-mono);
    font-size: 0.92rem;
    max-width: 100%;
    overflow-x: auto;
  }
  .hero-install code { color: var(--text); white-space: nowrap; }
  .hero-install code::before { content: "$ "; color: var(--jade); }
  .copy-btn {
    flex-shrink: 0;
    display: grid; place-items: center;
    width: 34px; height: 34px;
    border-radius: 8px;
    background: var(--surface);
    border: 1px solid var(--border);
    color: var(--text-muted);
    cursor: pointer;
    transition: all 0.2s ease;
  }
  .copy-btn:hover { color: var(--text); background: var(--surface-hover); }
  .copy-btn.copied { color: var(--jade); border-color: var(--jade); }

  .hero-engines {
    display: flex;
    flex-wrap: wrap;
    gap: 26px;
    margin-top: 40px;
    list-style: none;
    color: var(--text-faint);
    font-size: 0.9rem;
  }
  .hero-engines li { display: inline-flex; align-items: center; gap: 9px; }
  .hero-engines span {
    width: 9px; height: 9px; border-radius: 50%;
    background: var(--c);
    box-shadow: 0 0 12px var(--c);
  }

  /* STATS */
  .stats-band {
    border-block: 1px solid var(--border);
    background: var(--bg-soft);
  }
  .stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
    padding-block: 34px;
  }
  .stat { text-align: center; }
  .stat-n {
    display: block;
    font-size: 1.65rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    background: var(--grad);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .stat-label {
    font-size: 0.86rem;
    color: var(--text-faint);
  }

  /* FEATURES */
  .features-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }
  .feature-icon {
    display: grid; place-items: center;
    width: 46px; height: 46px;
    border-radius: 12px;
    background: var(--grad-soft);
    border: 1px solid var(--border);
    color: var(--jade);
    margin-bottom: 18px;
  }
  .feature h3 { font-size: 1.18rem; margin-bottom: 9px; }
  .feature p { font-size: 0.96rem; }

  /* ENGINES */
  .engines-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }
  .engine { padding-top: 30px; }
  .engine-bar {
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 3px;
    opacity: 0.85;
  }
  .engine-tag {
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }
  .engine h3 { font-size: 1.4rem; margin-block: 10px 12px; }
  .engine p { font-size: 0.96rem; }

  /* ARCHITECTURE */
  .arch-section { background: var(--bg-soft); border-block: 1px solid var(--border); }
  .arch {
    display: flex;
    flex-direction: column;
    gap: 14px;
    max-width: 860px;
  }
  .arch-layer {
    border: 1px solid var(--border);
    border-radius: 12px;
    background: var(--surface);
    padding: 18px 22px;
  }
  .arch-core {
    text-align: center;
    background: var(--grad-soft);
