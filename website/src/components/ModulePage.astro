---
import { getCollection, render } from "astro:content";
import Layout from "../layouts/Layout.astro";
import { MODULES } from "../data/modules";
import { MODULE_PAGE, homeBase, type Locale } from "../i18n/ui";

interface Props {
  slug: string;
  lang: Locale;
}

const { slug, lang } = Astro.props;
const t = MODULE_PAGE[lang];
const desc = MODULES.find((m) => m.name === slug)?.desc[lang] ?? "";

// Prefer the public API reference in docs/api; fall back to the crate README.
const apiId = slug.replace(/^rong_/, "");
const apiDocs = await getCollection("apiDocs");
let doc = apiDocs.find((e) => e.id === apiId);
let source = `docs/api/${apiId}.md`;
if (!doc) {
  const readmes = await getCollection("moduleReadmes");
  doc = readmes.find((e) => e.id.split("/")[0] === slug);
  source = `modules/${slug}/README.md`;
}
if (!doc) {
  throw new Error(`No API doc found for module ${slug}`);
}
const { Content } = await render(doc);

const base = import.meta.env.BASE_URL;
const home = homeBase(lang, base);
const repo = "https://github.com/LingXia-Dev/Rong";
---

<Layout lang={lang} title={t.title(slug)} description={t.description(slug, desc)}>
  <div class="container module-page">
    <aside class="module-nav">
      <a class="module-nav-back" href={`${home}/#modules`}>{t.allModules}</a>
      <nav aria-label={t.modules}>
        {MODULES.map((m) => (
          <a class:list={["module-nav-link", { "is-current": m.name === slug }]} href={`${home}/modules/${m.name}/`}>
            {m.name}
          </a>
        ))}
      </nav>
    </aside>

    <article class="module-doc">
      <nav class="crumbs" aria-label="Breadcrumb">
        <a href={`${home}/`}>{t.home}</a>
        <span>/</span>
        <a href={`${home}/#modules`}>{t.modules}</a>
        <span>/</span>
        <span class="crumbs-here">{slug}</span>
      </nav>

      <header class="module-head">
        <h1><code>{slug}</code></h1>
        <p>{desc}</p>
        <div class="module-links">
          <a class="btn btn-ghost" href={`${repo}/tree/master/modules/${slug}`} target="_blank" rel="noopener">{t.source}</a>
          <a class="btn btn-ghost" href={`https://crates.io/crates/${slug}`} target="_blank" rel="noopener">{t.cratesIo}</a>
          <a class="btn btn-ghost" href={`${repo}/blob/master/${source}`} target="_blank" rel="noopener">{t.editPage}</a>
        </div>
      </header>

      {t.englishOnlyNote && <p class="lang-note">{t.englishOnlyNote}</p>}

      <div class="prose">
        <Content />
      </div>
    </article>
  </div>
</Layout>

<style>
  .module-page {
    display: grid;
    grid-template-columns: 230px minmax(0, 1fr);
    gap: 56px;
    padding-block: 48px 96px;
  }

  /* Sidebar */
  .module-nav {
    position: sticky;
    top: 92px;
    align-self: start;
    max-height: calc(100vh - 120px);
    overflow-y: auto;
    padding-right: 8px;
  }
  .module-nav-back {
    display: block;
    font-size: 0.85rem;
    color: var(--text-faint);
    margin-bottom: 16px;
    transition: color 0.2s ease;
  }
  .module-nav-back:hover { color: var(--text); }
  .module-nav-link {
    display: block;
    padding: 6px 12px;
    border-left: 2px solid var(--border);
    font-family: var(--font-mono);
    font-size: 0.84rem;
    color: var(--text-muted);
    transition: color 0.2s ease, border-color 0.2s ease, background 0.2s ease;
  }
  .module-nav-link:hover { color: var(--text); background: var(--surface); }
  .module-nav-link.is-current {
    color: var(--jade);
    border-left-color: var(--jade);
    background: var(--surface);
  }

  /* Breadcrumbs */
  .crumbs {
    display: flex;
    gap: 10px;
    font-size: 0.85rem;
    color: var(--text-faint);
    margin-bottom: 28px;
  }
  .crumbs a { transition: color 0.2s ease; }
  .crumbs a:hover { color: var(--text); }
  .crumbs-here { color: var(--text-muted); }

  /* Header */
  .module-head {
    padding-bottom: 28px;
    margin-bottom: 36px;
    border-bottom: 1px solid var(--border);
  }
  .module-head h1 {
    font-size: clamp(1.7rem, 3.5vw, 2.4rem);
  }
  .module-head h1 code {
    font-family: var(--font-mono);
    background: var(--grad);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .module-head > p {
    margin-top: 10px;
    font-size: 1.05rem;
  }
  .module-links {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 20px;
  }
  .module-links .btn {
    padding: 7px 15px;
    font-size: 0.85rem;
  }

  /* Untranslated-content note */
  .lang-note {
    margin-bottom: 28px;
    padding: 10px 16px;
    border: 1px solid var(--border);
    border-left: 3px solid var(--gold);
    border-radius: 8px;
    background: var(--surface);
    font-size: 0.9rem;
    color: var(--text-muted);
  }

  /* Rendered markdown */
  .prose :global(h1) {
    display: none; /* the doc's own H1 duplicates the page header */
  }
  .prose :global(h2) {
    font-size: 1.45rem;
    margin: 2.2em 0 0.7em;
    padding-top: 0.6em;
    border-top: 1px solid var(--border);
  }
  .prose :global(h2:first-child) { margin-top: 0; border-top: none; padding-top: 0; }
  .prose :global(h3) {
    font-size: 1.12rem;
    margin: 1.8em 0 0.6em;
  }
  .prose :global(h3 code) { font-size: 1em; }
  .prose :global(p) {
    margin-block: 0.9em;
    color: var(--text-muted);
  }
  .prose :global(ul), .prose :global(ol) {
    margin: 0.9em 0 0.9em 1.4em;
    color: var(--text-muted);
  }
  .prose :global(li) { margin-block: 0.35em; }
  .prose :global(li::marker) { color: var(--jade); }
  .prose :global(a) {
    color: var(--jade);
    text-decoration: underline;
    text-decoration-color: rgba(62, 219, 178, 0.35);
    text-underline-offset: 3px;
  }
  .prose :global(a:hover) { text-decoration-color: var(--jade); }
  .prose :global(code:not(.astro-code code)) {
    font-family: var(--font-mono);
    font-size: 0.88em;
    background: var(--surface-hover);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 0.12em 0.42em;
    color: var(--text);
  }
  .prose :global(.astro-code) { margin-block: 1.1em; }
  .prose :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin-block: 1.2em;
    font-size: 0.92rem;
  }
  .prose :global(th), .prose :global(td) {
    border: 1px solid var(--border);
    padding: 9px 14px;
    text-align: left;
  }
  .prose :global(th) {
    background: var(--surface);
    color: var(--text);
    font-weight: 600;
  }
  .prose :global(td) { color: var(--text-muted); }
  .prose :global(blockquote) {
    border-left: 3px solid var(--jade);
    padding-left: 16px;
    margin-block: 1.1em;
    color: var(--text-muted);
  }

  @media (max-width: 860px) {
    .module-page {
      grid-template-columns: 1fr;
      gap: 0;
    }
    .module-nav { display: none; }
  }
</style>
